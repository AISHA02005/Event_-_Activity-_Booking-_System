<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.controllers.ReviewControllerFX"
            styleClass="root-pane">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="16" styleClass="top-bar">
            <padding><Insets top="12" right="20" bottom="12" left="20"/></padding>
            <Button text="⬅ Home" onAction="#goHome" styleClass="nav-btn"/>
            <Label text="⭐  Reviews" styleClass="screen-title"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="20">
            <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>

            <!-- Add Review -->
            <VBox styleClass="card" spacing="14">
                <Label text="Leave a Review" styleClass="card-heading"/>
                <GridPane hgap="14" vgap="10">
                    <Label text="User ID:"    GridPane.columnIndex="0" GridPane.rowIndex="0" styleClass="form-label"/>
                    <TextField fx:id="reviewUserIdField"  promptText="User ID"
                               GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="140"/>

                    <Label text="Event ID:"   GridPane.columnIndex="0" GridPane.rowIndex="1" styleClass="form-label"/>
                    <TextField fx:id="reviewEventIdField" promptText="Event ID"
                               GridPane.columnIndex="1" GridPane.rowIndex="1" prefWidth="140"/>

                    <Label text="Rating:"     GridPane.columnIndex="0" GridPane.rowIndex="2" styleClass="form-label"/>
                    <ComboBox fx:id="ratingCombo"
                              GridPane.columnIndex="1" GridPane.rowIndex="2" prefWidth="100"/>

                    <Label text="Comment:"    GridPane.columnIndex="0" GridPane.rowIndex="3"
                           styleClass="form-label" VBox.vgrow="ALWAYS"/>
                    <TextArea fx:id="commentArea" promptText="Write your review…"
                              prefHeight="80" wrapText="true"
                              GridPane.columnIndex="1" GridPane.rowIndex="3" prefWidth="340"/>
                </GridPane>

                <Button text="⭐  Submit Review" onAction="#handleAddReview" styleClass="primary-btn"/>
                <Label fx:id="reviewStatusLabel" styleClass="result-label" wrapText="true"/>
            </VBox>

            <!-- Reviews table -->
            <VBox styleClass="card" spacing="10" VBox.vgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Label text="All Reviews" styleClass="card-heading" HBox.hgrow="ALWAYS"/>
                    <Button text="🔄 Refresh" onAction="#loadAllReviews" styleClass="outline-btn"/>
                </HBox>
                <TableView fx:id="reviewsTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colRevId"      text="ID"      prefWidth="60"/>
                        <TableColumn fx:id="colRevUser"    text="User"    prefWidth="70"/>
                        <TableColumn fx:id="colRevEvent"   text="Event"   prefWidth="70"/>
                        <TableColumn fx:id="colRevRating"  text="Rating"  prefWidth="100"/>
                        <TableColumn fx:id="colRevComment" text="Comment" prefWidth="380"/>
                    </columns>
                </TableView>
            </VBox>
        </VBox>
    </center>
</BorderPane>
