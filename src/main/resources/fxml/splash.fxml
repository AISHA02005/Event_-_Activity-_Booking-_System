<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.controllers.SplashController"
      alignment="CENTER" spacing="30"
      styleClass="splash-root">
    <padding><Insets top="80" right="60" bottom="80" left="60"/></padding>

    <Label fx:id="titleLabel"  styleClass="splash-title"    wrapText="true"/>
    <Label fx:id="subtitleLabel" styleClass="splash-subtitle" wrapText="true"/>

    <Button fx:id="enterButton" text="✨  Enter System"
            styleClass="primary-btn" onAction="#handleEnter"
            prefWidth="220" prefHeight="50"/>
</VBox>
